{
  "name": "Executive Analytics Theme",
  "dataColors": [
    "#2563EB",
    "#10B981",
    "#F59E0B",
    "#EF4444",
    "#8B5CF6",
    "#06B6D4",
    "#64748B",
    "#EC4899"
  ],
  "background": "#F4F6F8",
  "foreground": "#1F2937",
  "tableAccent": "#2563EB",

  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI",
            "fontSize": 14,
            "color": {
              "solid": {
                "color": "#111827"
              }
            }
          }
        ],
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#374151"
              }
            }
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  },

  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#111827"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 13,
      "color": "#1F2937"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 28,
      "color": "#111827"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 11,
      "color": "#4B5563"
    }
  }
}